WIRIS_NET_SHOW_IMAGE_URL=

SENTRY_ENVIRONMENT=
SENTRY_LARAVEL_DSN=

# NQ
NQ_URL=URL_NQ
NQ_SALT=SECURE_ROUTE

# Feature Flags
# Control de generación de PDFs por período
# true: Genera 1 PDF unificado por curso con todas las semanas del bloque
# false: Genera PDFs individuales por cada semana
FEATURE_MATERIAL_GENERATE_BY_WEEK_BLOCK=true
CORS_ALLOWED_ORIGINS=http://localhost:5137,
APP_COOKIE_DOMAIN=localhost

APP_PREFIX_COOKIE=local|testing|develop|production

# Learnex API Token
LEARNEX_API_TOKEN=
API_PUBLIC_TOKEN=

RATE_LIMIT_WHITELIST_IPS=127.0.0.1

BATCH_PDF_GENERATION=false
HORIZON_PROCESSES=3
