APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION_MASTER=
DB_HOST_MASTER=
DB_PORT_MASTER=
DB_DATABASE_MASTER=
DB_USERNAME_MASTER=
DB_PASSWORD_MASTER=

DB_CONNECTION_STAND_BY=
DB_HOST_STAND_BY=
DB_PORT_STAND_BY=
DB_DATABASE_STAND_BY=
DB_USERNAME_STAND_BY=
DB_PASSWORD_STAND_BY=

BROADCAST_DRIVER=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_QUEUE=
REDIS_QUEUE_INDEX=
REDIS_QUEUE_DIAG=

CACHE_DRIVER=file
MEMCACHED_HOST=127.0.0.1
MEMCACHED_PORT=

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
